# Parsing (LlamaParse)
LLAMA_CLOUD_API_KEY=

# Embeddings (NVIDIA)
NVIDIA_API_KEY=
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
VECTOR_ENABLED=true

# LLM - Groq (primary) + OpenRouter (fallback)
GROQ_API_KEY=
OPENROUTER_API_KEY=
# Comma-separated provider:model pairs. Tried in order; 429 triggers next.
LLM_FALLBACK_CHAIN=groq:openai/gpt-oss-120b,groq:openai/gpt-oss-20b,groq:llama-3.3-70b-versatile,groq:llama-3.1-8b-instant,openrouter:openrouter/free
# Optional pinned OpenRouter free models you can swap in ahead of openrouter/free:
# openrouter:openai/gpt-oss-120b:free
# openrouter:qwen/qwen3-coder:free
# openrouter:nvidia/llama-3.1-nemotron-ultra-253b-v1:free
# openrouter:meta-llama/llama-3.3-70b-instruct:free

# Advanced RAG (all ON by default, toggle in Admin)
HYDE_ENABLED=true
DEEP_REWRITE_ENABLED=true
DECOMPOSITION_ENABLED=true
RERANKER_ENABLED=true

# Ingestion tuning
INGESTION_PARSE_WORKERS=4
INGESTION_PARSE_QUEUE_SIZE=32
EMBEDDING_BATCH_SIZE=32
VECTOR_UPSERT_BATCH_SIZE=64
BM25_COMMIT_BATCH_SIZE=256
INDEX_SWAP_MODE=atomic_swap

# General
IGNORE_TEST_DEMO_INDEXES=true
CHUNKING_MODE=semantic_hybrid
# FASTAPI_PORT=8000  (default, override with uvicorn --port)
