# Environment variables for Multimodal Agentic RAG
GEMINI_API_KEY=
# Optional: override embedding model
EMBEDDING_MODEL=all-mpnet-base-v2
VECTOR_ENABLED=false
FAST_PATH_ENABLED=true
RERANKER_ENABLED=false
HYDE_ENABLED=false
DEEP_REWRITE_ENABLED=false
DECOMPOSITION_ENABLED=false
# Set true only if you want strict OCR-only parsing with explicit RapidOCR model assets.
DOCLING_OCR_FORCE=false
DOCLING_OCR_DET_MODEL_PATH=
DOCLING_OCR_CLS_MODEL_PATH=
DOCLING_OCR_REC_MODEL_PATH=
DOCLING_OCR_REC_KEYS_PATH=
DOCLING_OCR_FONT_PATH=
DOCLING_OCR_AUTO=true
IGNORE_TEST_DEMO_INDEXES=true
# Comma-separated list parsed by app defaults; keep default unless debugging contamination.
# DEMO_INDEX_MARKERS=doc1,Apple revenue is $100.
INGESTION_PARSE_WORKERS=4
INGESTION_PARSE_QUEUE_SIZE=32
EMBEDDING_BATCH_SIZE=32
VECTOR_UPSERT_BATCH_SIZE=64
BM25_COMMIT_BATCH_SIZE=256
INDEX_SWAP_MODE=atomic_swap
# Streamlit settings
STREAMLIT_PORT=8501
